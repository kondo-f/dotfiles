{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "provider": {
    "azure-foundry-base-models": {
      "name": "Azure Foundry Base Models",
      "options": {
        "baseURL": "https://{env:AZURE_RESOURCE_NAME}.services.ai.azure.com/models",
        "apiKey": "{env:MICROSOFT_FOUNDRY_API_KEY}"
      },
      "models": {
        "Kimi-K2.5": {
          "name": "Kimi-K2.5",
          "limit": {
            "context": 262144,
            "output": 10000
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        }
      }
    }
  }
}
